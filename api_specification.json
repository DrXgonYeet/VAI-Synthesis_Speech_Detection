{
  "name": "VAI-Synthesis_Speech_Detection",
  "version": "1.0.0",
  "description": "Detects AI-generated vs human speech in 5 Indian languages",
  "authentication": {
    "type": "API Key",
    "header": "x-api-key",
    "default_key": "demo-key-123",
    "generate_new": "Contact Administrator"
  },
  "base_url": "https://vai-synthesis-speech-detection.onrender.com",
  "endpoints": [
    {
      "method": "GET",
      "path": "/",
      "description": "Root endpoint / Welcome message"
    },
    {
      "method": "GET",
      "path": "/health",
      "description": "Health check and system status",
      "response": {
        "status": "healthy",
        "model_loaded": true,
        "supported_languages": [
          "Tamil",
          "English",
          "Hindi",
          "Malayalam",
          "Telugu"
        ],
        "device": "cpu"
      }
    },
    {
      "method": "POST",
      "path": "/analyze-voice",
      "description": "Analyze voice sample (Base64 input)",
      "request": {
        "audio_base64": "UklGRiR9AABXQVZFZm10IBAAAAABAAEAgD4AAAB9AAACABAAZGF0YQB9AAAAAAALrhW1H8soqjAWN9473T79PzU/izwTOPAxUCpu... (truncated)",
        "language": "English"
      },
      "response": {
        "classification": "HUMAN",
        "confidence": 0.92,
        "processing_time_ms": 245.3,
        "language": "English",
        "model_version": "VoiceResNet-FineTuned-v1"
      },
      "curl_example": "curl -X POST https://vai-synthesis-speech-detection.onrender.com/analyze-voice \\\n  -H \"Content-Type: application/json\" \\\n  -H \"x-api-key: demo-key-123\" \\\n  -d '{\n    \"audio_base64\": \"<YOUR_BASE64_STRING>\",\n    \"language\": \"English\"\n  }'"
    },
    {
      "method": "GET",
      "path": "/docs",
      "description": "Interactive Swagger UI documentation"
    }
  ],
  "supported_languages": [
    "Tamil",
    "English",
    "Hindi",
    "Malayalam",
    "Telugu"
  ],
  "response_formats": {
    "classification": "AI_GENERATED or HUMAN",
    "confidence": "0.0 to 1.0",
    "processing_time_ms": "milliseconds"
  },
  "authentication_required": [
    "analyze-voice"
  ],
  "rate_limits": "1000 requests/day",
  "max_audio_size": "10MB",
  "expected_latency": "200-500ms per request",
  "deployment_options": [
    "Render"
  ]
}